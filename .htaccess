RewriteEngine On

# 1. Remove .php from URL
# If the request is for a file that doesn't exist, check if appending .php works
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# 2. Redirect /file.php to /file (Optional but recommended for SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php[\s\?] [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# Handle API routing (if not handled by api/.htaccess)
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]
RewriteRule ^api/(.*)$ api/index.php [QSA,L]
